<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card p-4 mt-3">
      <h2 class="fw-bold mb-1"><i class="bi bi-pencil-square" style="color:#6366f1;"></i> Edit Project</h2>
      <p class="text-muted mb-4">Update your project details</p>

      <form method="POST" action="/projects/<%= project.id %>">
        <div class="mb-3">
          <label class="form-label fw-semibold">Project Name <span class="text-danger">*</span></label>
          <input class="form-control" name="name" value="<%= project.name %>" required />
        </div>
        <div class="mb-4">
          <label class="form-label fw-semibold">Description</label>
          <textarea class="form-control" name="description" rows="4"><%= project.description %></textarea>
        </div>
        <div class="d-flex gap-2">
          <button class="btn btn-bc">Save Changes</button>
          <a href="/projects/<%= project.id %>" class="btn btn-outline-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
