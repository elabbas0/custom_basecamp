<%- include('../partials/header') %>

<div class="row">
  <div class="col-lg-8">
    <div class="card p-4">
      <div class="d-flex justify-content-between align-items-start">
        <div>
          <h2 class="fw-bold mb-1"><%= project.name %></h2>
          <p class="text-muted"><%= project.description || 'No description provided.' %></p>
        </div>
        <% if (locals.currentUser && (currentUser.id === project.owner || currentUser.role === 'admin')) { %>
          <div class="d-flex gap-2">
            <a href="/projects/<%= project.id %>/edit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i> Edit</a>
            <form method="POST" action="/projects/<%= project.id %>/delete"
              onsubmit="return confirm('Delete this project?')">
              <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Delete</button>
            </form>
          </div>
        <% } %>
      </div>

      <hr>

      <div class="row g-3 mt-1">
        <div class="col-sm-6">
          <div class="p-3 rounded" style="background:#f8fafc;">
            <small class="text-muted text-uppercase" style="letter-spacing:1px;font-size:0.7rem;">Owner</small>
            <p class="mb-0 fw-semibold"><i class="bi bi-person-circle"></i> <%= ownerUser ? ownerUser.name : project.owner.substring(0,8) + '...' %></p>
          </div>
        </div>
        <div class="col-sm-6">
          <div class="p-3 rounded" style="background:#f8fafc;">
            <small class="text-muted text-uppercase" style="letter-spacing:1px;font-size:0.7rem;">Created</small>
            <p class="mb-0 fw-semibold"><i class="bi bi-calendar3"></i> <%= new Date(project.createdAt).toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'}) %></p>
          </div>
        </div>
      </div>

      <%# Members section %>
      <div class="mt-4">
        <h6 class="fw-bold mb-2"><i class="bi bi-people"></i> Members</h6>

        <% if (members.length === 0) { %>
          <p class="text-muted small">No members yet.</p>
        <% } else { %>
          <ul class="list-group list-group-flush mb-3">
            <% members.forEach(member => { %>
              <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                <span><i class="bi bi-person-circle me-2 text-muted"></i><%= member.name %> <small class="text-muted"><%= member.email %></small></span>
                <% if (locals.currentUser && (currentUser.id === project.owner || currentUser.role === 'admin')) { %>
                  <form method="POST" action="/projects/<%= project.id %>/members/<%= member.id %>/remove" onsubmit="return confirm('Remove <%= member.name %>?')">
                    <button class="btn btn-sm btn-outline-danger"><i class="bi bi-person-dash"></i></button>
                  </form>
                <% } %>
              </li>
            <% }) %>
          </ul>
        <% } %>

        <% if (locals.currentUser && (currentUser.id === project.owner || currentUser.role === 'admin')) { %>
          <% if (typeof query !== 'undefined' && query.memberError) { %>
            <div class="alert alert-danger py-2 small"><%= query.memberError %></div>
          <% } %>
          <form method="POST" action="/projects/<%= project.id %>/members" class="d-flex gap-2">
            <input type="email" name="email" class="form-control form-control-sm" placeholder="Add by email..." required>
            <button class="btn btn-sm btn-bc text-nowrap"><i class="bi bi-person-plus"></i> Add</button>
          </form>
        <% } %>
      </div>

      <div class="mt-4">
        <a href="/projects" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> All Projects</a>
      </div>
    </div>
  </div>
</div>

<div class="row g-4 mt-1">

  <%# Threads %>
  <div class="col-lg-6">
    <div class="card p-4 h-100">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-bold mb-0"><i class="bi bi-chat-left-text"></i> Threads</h5>
        <% if (locals.currentUser && (currentUser.id === project.owner || currentUser.role === 'admin')) { %>
          <a href="/projects/<%= project.id %>/threads/new" class="btn btn-sm btn-bc">
            <i class="bi bi-plus"></i> New Thread
          </a>
        <% } %>
      </div>
      <% if (!threads || threads.length === 0) { %>
        <p class="text-muted mb-0">No threads yet.</p>
      <% } else { %>
        <ul class="list-group list-group-flush">
          <% threads.forEach(thread => { %>
            <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
              <a href="/projects/<%= project.id %>/threads/<%= thread.id %>" class="fw-semibold text-decoration-none">
                <i class="bi bi-chat-right-dots text-muted me-2"></i><%= thread.title %>
              </a>
              <% if (locals.currentUser && (currentUser.id === project.owner || currentUser.role === 'admin')) { %>
                <div class="d-flex gap-2">
                  <a href="/projects/<%= project.id %>/threads/<%= thread.id %>/edit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
                  <form method="POST" action="/projects/<%= project.id %>/threads/<%= thread.id %>/delete" onsubmit="return confirm('Delete this thread?')">
                    <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                  </form>
                </div>
              <% } %>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </div>
  </div>

  <%# Attachments %>
  <div class="col-lg-6">
    <div class="card p-4 h-100">
      <h5 class="fw-bold mb-3"><i class="bi bi-paperclip"></i> Attachments</h5>
      <% if (locals.currentUser && (project.members.includes(currentUser.id) || currentUser.id === project.owner)) { %>
        <form method="POST" action="/projects/<%= project.id %>/attachments" enctype="multipart/form-data" class="mb-3">
          <div class="input-group">
            <input type="file" name="file" class="form-control" accept=".png,.jpg,.pdf,.txt" required>
            <button class="btn btn-bc" type="submit"><i class="bi bi-upload"></i> Upload</button>
          </div>
          <small class="text-muted">Allowed: png, jpg, pdf, txt</small>
        </form>
      <% } %>
      <% if (!attachments || attachments.length === 0) { %>
        <p class="text-muted mb-0">No attachments yet.</p>
      <% } else { %>
        <ul class="list-group list-group-flush">
          <% attachments.forEach(att => { %>
            <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
              <div>
                <% const icons = { png: 'bi-file-image', jpg: 'bi-file-image', pdf: 'bi-file-pdf', txt: 'bi-file-text' }; %>
                <i class="bi <%= icons[att.format] || 'bi-file' %> me-2 text-muted"></i>
                <a href="/projects/<%= project.id %>/attachments/<%= att.id %>/download" class="fw-semibold text-decoration-none">
                  <%= att.filename %>
                </a>
                <span class="badge bg-secondary ms-2"><%= att.format.toUpperCase() %></span>
              </div>
              <% if (locals.currentUser && (att.userId === currentUser.id || currentUser.id === project.owner)) { %>
                <form method="POST" action="/projects/<%= project.id %>/attachments/<%= att.id %>/delete" onsubmit="return confirm('Delete?')">
                  <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                </form>
              <% } %>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </div>
  </div>

</div>

<%- include("../partials/footer") %>
