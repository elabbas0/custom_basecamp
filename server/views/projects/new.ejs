<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card p-4 mt-3">
      <h2 class="fw-bold mb-1"><i class="bi bi-plus-circle" style="color:#31c48d;"></i> New Project</h2>
      <p class="text-muted mb-4">Set up your project in seconds</p>

      <form method="POST" action="/projects">
        <div class="mb-3">
          <label class="form-label fw-semibold">Project Name <span class="text-danger">*</span></label>
          <input class="form-control" name="name" placeholder="e.g. Website Redesign" required />
        </div>
        <div class="mb-4">
          <label class="form-label fw-semibold">Description</label>
          <textarea class="form-control" name="description" rows="4" placeholder="What's this project about?"></textarea>
        </div>
        <div class="d-flex gap-2">
          <button class="btn btn-bc">Create Project</button>
          <a href="/projects" class="btn btn-outline-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
