<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="fw-bold mb-0"><i class="bi bi-folder2-open" style="color:#31c48d;"></i> Projects</h2>
  <a href="/projects/new" class="btn btn-bc"><i class="bi bi-plus-lg"></i> New Project</a>
</div>

<% const projectList = Object.values(projects || {}); %>

<% if (projectList.length === 0) { %>
  <div class="text-center py-5">
    <i class="bi bi-folder2" style="font-size:4rem; color:#ccc;"></i>
    <h4 class="mt-3 text-muted">No projects yet</h4>
    <p class="text-muted">Create your first project to get started.</p>
    <a href="/projects/new" class="btn btn-bc mt-2">Create a Project</a>
  </div>
<% } else { %>
  <div class="row g-3">
    <% projectList.forEach(p => { %>
      <div class="col-md-4">
        <a href="/projects/<%= p.id %>" class="card p-4 text-decoration-none text-dark project-card d-block h-100">
          <div class="d-flex align-items-start gap-3">
            <div style="width:44px;height:44px;border-radius:10px;background:#31c48d;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.3rem;flex-shrink:0;">
              <i class="bi bi-kanban"></i>
            </div>
            <div>
              <h5 class="fw-bold mb-1"><%= p.name %></h5>
              <p class="text-muted mb-0" style="font-size:0.88rem;"><%= p.description || 'No description' %></p>
            </div>
          </div>
          <div class="mt-3 pt-2 border-top d-flex justify-content-between">
            <small class="text-muted"><i class="bi bi-person"></i> <%= p.owner.substring(0,8) %>...</small>
            <small class="text-muted"><i class="bi bi-clock"></i> <%= new Date(p.createdAt).toLocaleDateString() %></small>
          </div>
        </a>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include('../partials/footer') %>
