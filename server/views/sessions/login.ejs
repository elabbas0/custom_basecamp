<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card p-4 mt-3">
      <h2 class="fw-bold mb-1"><i class="bi bi-box-arrow-in-right" style="color:#31c48d;"></i> Log In</h2>
      <p class="text-muted mb-4">Welcome back to MyBasecamp</p>

      <% if (locals.error && error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <form method="POST" action="/session/login">
        <div class="mb-3">
          <label class="form-label fw-semibold">Email Address</label>
          <input class="form-control" name="email" type="email" placeholder="jane@example.com" required />
        </div>
        <div class="mb-4">
          <label class="form-label fw-semibold">Password</label>
          <input class="form-control" name="password" type="password" placeholder="Your password" required />
        </div>
        <button class="btn btn-bc w-100">Log In</button>
      </form>

      <p class="text-center text-muted mt-3 mb-0">Don't have an account? <a href="/users/new">Sign up</a></p>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
