<%- include('../partials/header') %>

<div class="row">
  <div class="col-lg-6">
    <div class="card p-4">
      <h4 class="fw-bold mb-4"><i class="bi bi-pencil"></i> Edit Message</h4>
      <form method="POST" action="/projects/<%= project.id %>/threads/<%= thread.id %>/messages/<%= message.id %>">
        <div class="mb-3">
          <label class="form-label fw-semibold">Message</label>
          <textarea name="body" class="form-control" rows="4" required><%= message.body %></textarea>
        </div>
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-bc">Save Changes</button>
          <a href="/projects/<%= project.id %>/threads/<%= thread.id %>" class="btn btn-outline-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
