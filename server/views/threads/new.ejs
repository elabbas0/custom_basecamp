<%- include('../partials/header') %>

<div class="row">
  <div class="col-lg-6">
    <div class="card p-4">
      <h4 class="fw-bold mb-4"><i class="bi bi-chat-left-text"></i> New Thread</h4>
      <form method="POST" action="/projects/<%= project.id %>/threads">
        <div class="mb-3">
          <label class="form-label fw-semibold">Title</label>
          <input type="text" name="title" class="form-control" placeholder="What's this thread about?" required>
        </div>
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-bc">Create Thread</button>
          <a href="/projects/<%= project.id %>" class="btn btn-outline-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
