<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>MyBasecamp</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    body { background-color: #f4f6f9; }
    .navbar-brand { font-weight: 700; font-size: 1.4rem; letter-spacing: -0.5px; }
    .navbar-brand span { color: #31c48d; }
    .card { border: none; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.07); }
    .btn-bc { background: #31c48d; color: #fff; border: none; }
    .btn-bc:hover { background: #27a676; color: #fff; }
    .badge-admin { background: #f59e0b; color: #fff; font-size: 0.7rem; padding: 3px 8px; border-radius: 20px; }
    .project-card:hover { transform: translateY(-2px); transition: transform 0.2s; box-shadow: 0 6px 20px rgba(0,0,0,0.1); }
    @keyframes slideIn { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:translateY(0); } }
    @keyframes slideOut { from { opacity:1; transform:translateY(0); } to { opacity:0; transform:translateY(16px); } }
    #toast-container { position:fixed; bottom:24px; left:24px; display:flex; flex-direction:column; gap:10px; z-index:9999; max-width:320px; pointer-events:none; }
    .bc-toast { background:#1a1a2e; color:#fff; border-radius:12px; padding:14px 16px; box-shadow:0 4px 20px rgba(0,0,0,0.35); animation:slideIn 0.2s ease; pointer-events:all; cursor:pointer; border-left:4px solid #31c48d; }
    .bc-toast:hover { background:#2a2a3e; }
    .bc-toast-thread { font-size:0.7rem; color:#31c48d; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:4px; }
    .bc-toast-sender { font-weight:600; font-size:0.9rem; margin-bottom:2px; }
    .bc-toast-body { font-size:0.85rem; color:#adb5bd; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  </style>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark" style="background:#1a1a2e;">
  <div class="container">
    <a class="navbar-brand" href="/"><i class="bi bi-mountain"></i> My<span>Base</span>camp</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navMain">
      <ul class="navbar-nav ms-auto align-items-center gap-2">
        <% if (locals.currentUser) { %>
          <li class="nav-item">
            <a class="nav-link" href="/projects"><i class="bi bi-folder2-open"></i> Projects</a>
          </li>
          <% if (currentUser.role === 'admin') { %>
          <li class="nav-item">
            <a class="nav-link" href="/users"><i class="bi bi-people"></i> Users</a>
          </li>
          <% } %>
          <li class="nav-item">
            <a class="nav-link" href="/projects/new"><i class="bi bi-plus-circle"></i> New Project</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/users/<%= currentUser.id %>">
              <i class="bi bi-person-circle"></i> <%= currentUser.name %>
              <% if (currentUser.role === 'admin') { %><span class="badge-admin ms-1">Admin</span><% } %>
            </a>
          </li>
          <li class="nav-item">
            <form method="POST" action="/session/logout" class="mb-0">
              <button class="btn btn-sm btn-outline-light" type="submit"><i class="bi bi-box-arrow-right"></i> Logout</button>
            </form>
          </li>
        <% } else { %>
          <li class="nav-item"><a class="nav-link" href="/session/login">Login</a></li>
          <li class="nav-item"><a class="btn btn-bc btn-sm" href="/users/new">Sign Up</a></li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>
<div class="container py-4">

<div id="toast-container"></div>

<% if (locals.currentUser) { %>
<script>
  const __currentUserId = '<%= currentUser.id %>';
  const __currentThreadId = typeof threadId !== 'undefined' ? threadId : null;

  function playBeep() {
    try {
      const ctx = new (window.AudioContext || window.webkitAudioContext)();
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain);
      gain.connect(ctx.destination);
      osc.type = 'sine';
      osc.frequency.setValueAtTime(880, ctx.currentTime);
      osc.frequency.setValueAtTime(1100, ctx.currentTime + 0.1);
      gain.gain.setValueAtTime(0.25, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.35);
      osc.start(ctx.currentTime);
      osc.stop(ctx.currentTime + 0.35);
    } catch(e) {}
  }

  function showToast(data) {
    const container = document.getElementById('toast-container');
    const toast = document.createElement('div');
    toast.className = 'bc-toast';
    toast.innerHTML = `
      <div class="bc-toast-thread"><i class="bi bi-chat-left-text me-1"></i>${data.threadTitle}</div>
      <div class="bc-toast-sender"><i class="bi bi-person-circle me-1"></i>${data.userName}</div>
      <div class="bc-toast-body">${data.body}</div>
    `;
    toast.onclick = () => window.location.href = `/projects/${data.projectId}/threads/${data.threadId}`;
    container.appendChild(toast);
    setTimeout(() => {
      toast.style.animation = 'slideOut 0.2s ease forwards';
      setTimeout(() => toast.remove(), 200);
    }, 4000);
  }

  const __ws = new WebSocket('ws://' + location.host);
  __ws.addEventListener('open', () => {
    __ws.send(JSON.stringify({ type: 'register', userId: __currentUserId }));
  });

  __ws.addEventListener('message', (event) => {
    const data = JSON.parse(event.data);
    if (data.type !== 'new_message') return;

    // If we're currently on this thread, let threads/show.ejs handle the DOM append
    // Only show toast + sound for messages from OTHER users
    if (data.userId === __currentUserId) return;

    playBeep();
    showToast(data);
  });
</script>
<% } %>
